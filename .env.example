# ============================================================================
# CompadreFood — variáveis de ambiente
# Copie para .env.local (dev) e cadastre no painel da Vercel (prod).
# ============================================================================

# --- PAGOU.AI v2 (PIX + Cartão) — OBRIGATÓRIAS ------------------------------
# Chave SECRETA (server-side). Usada em /api/pix/create, /api/card/create e
# /api/payment/status. Pega no painel da Pagou.ai. NUNCA exponha no front.
PAGOUAI_SECRET_KEY=

# Chave PÚBLICA (client-side). Usada pelo SDK v3 que tokeniza o cartão no
# browser (3DS). Começa com pk_test_ (sandbox) ou pk_live_ (produção).
# Sem ela o pagamento por CARTÃO não funciona (o PIX funciona só com a secret).
NEXT_PUBLIC_PAGOUAI_PUBLIC_KEY=

# --- E-MAIL (Resend) — confirmação de pedido --------------------------------
# Chave da API do Resend (resend.com). Sem ela, o e-mail não dispara (o pedido
# confirma na tela mesmo assim — o envio é "best effort").
RESEND_API_KEY=
# Remetente VERIFICADO no Resend. Ex.: "CompadreFood <pedidos@seudominio.com>".
# Sem domínio verificado, o Resend só envia pro seu próprio e-mail (modo teste).
RESEND_FROM_EMAIL=
# (opcional) Responder-para. Ex.: suporte@compadrefood.com
RESEND_REPLY_TO=
# (opcional) E-mail da LOJA que recebe cópia de cada venda (aviso de pedido novo).
STORE_EMAIL=

# --- URL pública do site (logo do e-mail / link "Voltar à loja") ------------
# Ex.: https://compadrefood.com (sem barra no final)
NEXT_PUBLIC_APP_URL=

# --- KV / Webhook (e-mail garantido mesmo com aba fechada) — OPCIONAL --------
# Upstash Redis (REST). Sem essas duas, o sistema funciona normal SÓ pelo front
# (o e-mail pode não sair se o cliente pagar o PIX e fechar a aba sem voltar).
# Pega em upstash.com -> Redis -> Details -> "REST API".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Segredo do webhook da Pagou.ai. Se preenchido, o /api/webhook/pagou só aceita
# chamadas com ?secret=ESSE_VALOR (ou header). Recomendado.
PAGOUAI_WEBHOOK_SECRET=

# --- Carrinho abandonado (QStash) — OPCIONAL --------------------------------
# Token do QStash (vem junto no Upstash: console -> QStash). Sem ele, o e-mail
# de carrinho abandonado simplesmente não é agendado (resto funciona normal).
QSTASH_TOKEN=
